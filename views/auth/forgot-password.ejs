<!DOCTYPE html>
<html lang="en">

<head><%- include('../partials/head', { title: 'Forgot Password' }) %></head>

<body>
    <div class="bg-animated">
        <div class="bg-orb bg-orb-1"></div>
        <div class="bg-orb bg-orb-2"></div>
        <div class="bg-orb bg-orb-3"></div>
    </div>

    <div class="auth-page">
        <div class="auth-card" id="auth-card" style="position:relative">

            <!-- Step 1: Request OTP -->
            <div id="step-1">
                <div class="auth-logo">
                    <div class="fenix-auth-logo">
                        <svg width="36" height="36" viewBox="0 0 28 28" fill="none">
                            <rect width="28" height="28" rx="8" fill="url(#gl)" />
                            <line x1="8" y1="20" x2="20" y2="8" stroke="white" stroke-width="2.5"
                                stroke-linecap="round" />
                            <defs>
                                <linearGradient id="gl" x1="0" y1="0" x2="28" y2="28">
                                    <stop offset="0%" stop-color="#6366f1" />
                                    <stop offset="100%" stop-color="#8b5cf6" />
                                </linearGradient>
                            </defs>
                        </svg>
                    </div>
                    <h2 style="margin-top:16px">Reset Password</h2>
                    <p>Enter your email or phone number</p>
                </div>

                <div class="form-group">
                    <label class="form-label">Email or Phone</label>
                    <input type="text" id="identifier" class="form-control" placeholder="you@example.com or +1234567890"
                        autofocus>
                </div>

                <button class="btn btn-primary btn-lg" style="width:100%" id="send-otp-btn">
                    Send Verification Code
                </button>

                <p style="text-align:center;margin-top:20px;font-size:0.875rem">
                    Remember your password?
                    <a href="/login" style="color:var(--accent-primary);font-weight:600">Sign in</a>
                </p>
            </div>

            <!-- Step 2: Verify OTP -->
            <div id="step-2" style="display:none">
                <div class="auth-logo">
                    <div style="font-size:2.5rem;margin-bottom:12px">🔑</div>
                    <h2>Verification</h2>
                    <p id="reset-hint">Enter the 6-digit code sent to you</p>
                </div>

                <div class="otp-inputs" style="margin-bottom: 20px;">
                    <input type="text" maxlength="1" class="otp-input" data-index="0">
                    <input type="text" maxlength="1" class="otp-input" data-index="1">
                    <input type="text" maxlength="1" class="otp-input" data-index="2">
                    <input type="text" maxlength="1" class="otp-input" data-index="3">
                    <input type="text" maxlength="1" class="otp-input" data-index="4">
                    <input type="text" maxlength="1" class="otp-input" data-index="5">
                </div>

                <button class="btn btn-primary btn-lg" style="width:100%" id="verify-otp-btn">
                    Verify Code
                </button>

                <p style="text-align:center;margin-top:16px;font-size:0.875rem">
                    <a href="#" onclick="backToStep1()" style="color:var(--accent-primary);font-weight:600">← Back</a>
                </p>
            </div>

            <!-- Step 3: New Password -->
            <div id="step-3" style="display:none">
                <div class="auth-logo">
                    <div style="font-size:2.5rem;margin-bottom:12px">🔒</div>
                    <h2>New Password</h2>
                    <p>Please enter your new password</p>
                </div>

                <div class="form-group">
                    <label class="form-label">New Password</label>
                    <input type="password" id="new-password" class="form-control" placeholder="•••••••• (min 6 chars)">
                </div>

                <button class="btn btn-primary btn-lg" style="width:100%" id="reset-btn">
                    Reset Password
                </button>
            </div>
        </div>

    </div>
    </div>

    <script src="/js/app.js"></script>
    <script>
        window.addEventListener('load', () => { Theme.init(); Toast.init(); });

        let currentIdentifier = '';
        let currentCode = '';

        async function handleSendOtp() {
            const identifier = document.getElementById('identifier').value.trim();
            if (!identifier) {
                showErrorModal('Missing Field', 'Please enter your email or phone number.');
                return;
            }

            const btn = document.getElementById('send-otp-btn');
            btn.innerHTML = '<div class="spinner"></div> Sending...';
            btn.disabled = true;

            const res = await API.post('/auth/forgot-password-otp', { identifier });

            btn.innerHTML = 'Send Verification Code';
            btn.disabled = false;

            if (res.message) {
                currentIdentifier = res.identifier;
                document.getElementById('step-1').style.display = 'none';
                document.getElementById('step-2').style.display = 'block';
                document.querySelector('.otp-input').focus();
            } else {
                showErrorModal('Error', res.error || 'Failed to send code.');
            }
        }

        async function handleVerifyOtp() {
            const inputs = document.querySelectorAll('.otp-input');
            const code = Array.from(inputs).map(i => i.value).join('');

            if (code.length !== 6) {
                showErrorModal('Incomplete Code', 'Please enter all 6 digits.');
                return;
            }

            const btn = document.getElementById('verify-otp-btn');
            btn.innerHTML = '<div class="spinner"></div> Verifying...';
            btn.disabled = true;

            const res = await API.post('/auth/forgot-password-verify', { identifier: currentIdentifier, code });

            btn.innerHTML = 'Verify Code';
            btn.disabled = false;

            if (res.message) {
                currentCode = code;
                document.getElementById('step-2').style.display = 'none';
                document.getElementById('step-3').style.display = 'block';
                document.getElementById('new-password').focus();
            } else {
                showErrorModal('Wrong Code', res.error || 'Invalid code or something went wrong.');
            }
        }

        async function handleResetParams() {
            const new_password = document.getElementById('new-password').value;

            if (new_password.length < 6) {
                showErrorModal('Weak Password', 'New password must be at least 6 characters.');
                return;
            }

            const btn = document.getElementById('reset-btn');
            btn.innerHTML = '<div class="spinner"></div> Resetting...';
            btn.disabled = true;

            const res = await API.post('/auth/forgot-password-reset', { identifier: currentIdentifier, code: currentCode, new_password });

            btn.innerHTML = 'Reset Password';
            btn.disabled = false;

            if (res.message) {
                Toast.success('Password reset successfully!');
                setTimeout(() => window.location.href = '/login', 1000);
            } else {
                showErrorModal('Reset Failed', res.error || 'Failed to update password.');
            }
        }

        function backToStep1() {
            document.getElementById('step-2').style.display = 'none';
            document.getElementById('step-1').style.display = 'block';
            currentIdentifier = '';
        }

        // OTP logic and error modal reusing styled code from login
        function showErrorModal(title, msg) {
            const existing = document.getElementById('auth-error-banner');
            if (existing) existing.remove();
            const banner = document.createElement('div');
            banner.id = 'auth-error-banner';
            banner.style.cssText = [
                'display:flex', 'align-items:flex-start', 'gap:10px',
                'padding:12px 16px', 'border-radius:10px', 'margin-bottom:16px',
                'background:linear-gradient(135deg,rgba(239,68,68,0.12),rgba(239,68,68,0.05))',
                'border:1px solid rgba(239,68,68,0.3)',
                'animation:authErrSlide .35s cubic-bezier(.34,1.56,.64,1)',
            ].join(';');
            banner.innerHTML = `
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
        fill="none" stroke="#ef4444" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"
        style="flex-shrink:0;margin-top:1px">
        <circle cx="12" cy="12" r="10"/>
        <line x1="12" y1="8" x2="12" y2="12"/>
        <line x1="12" y1="16" x2="12.01" y2="16"/>
      </svg>
      <div style="flex:1;min-width:0">
        <div style="font-size:0.82rem;font-weight:700;color:#ef4444;margin-bottom:2px">${title}</div>
        <div style="font-size:0.8rem;color:rgba(239,68,68,0.8);line-height:1.4">${msg}</div>
      </div>
      <button onclick="closeErrorModal()" style="background:none;border:none;cursor:pointer;color:rgba(239,68,68,0.5);font-size:1rem;line-height:1;padding:0;flex-shrink:0" title="Dismiss">&#10005;</button>
    `;
            const activeForm = document.getElementById('step-1').style.display !== 'none'
                ? document.getElementById('step-1')
                : (document.getElementById('step-2').style.display !== 'none' ? document.getElementById('step-2') : document.getElementById('step-3'));
            activeForm.insertBefore(banner, activeForm.firstChild);
        }
        function closeErrorModal() {
            const b = document.getElementById('auth-error-banner');
            if (b) {
                b.style.animation = 'authErrOut .25s ease forwards';
                setTimeout(() => b.remove(), 250);
            }
        }

        document.querySelectorAll('.otp-input').forEach((input, idx, all) => {
            input.addEventListener('input', () => {
                input.value = input.value.replace(/\D/g, '');
                if (input.value) {
                    input.classList.add('filled');
                    if (idx < all.length - 1) all[idx + 1].focus();
                } else {
                    input.classList.remove('filled');
                }
            });
            input.addEventListener('keydown', e => {
                if (e.key === 'Backspace' && !input.value && idx > 0) {
                    all[idx - 1].focus();
                    all[idx - 1].classList.remove('filled');
                }
            });
        });

        document.getElementById('send-otp-btn').addEventListener('click', handleSendOtp);
        document.getElementById('verify-otp-btn').addEventListener('click', handleVerifyOtp);
        document.getElementById('reset-btn').addEventListener('click', handleResetParams);
    </script>
</body>

</html>