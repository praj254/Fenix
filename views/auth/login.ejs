<!DOCTYPE html>
<html lang="en">

<head><%- include('../partials/head', { title: 'Login' }) %></head>

<body>
  <div class="bg-animated">
    <div class="bg-orb bg-orb-1"></div>
    <div class="bg-orb bg-orb-2"></div>
    <div class="bg-orb bg-orb-3"></div>
  </div>

  <div class="auth-page">
    <div class="auth-card" id="auth-card">

      <!-- Login Form -->
      <div id="login-form">
        <div class="auth-logo">
          <div class="fenix-auth-logo">
            <svg width="36" height="36" viewBox="0 0 28 28" fill="none">
              <rect width="28" height="28" rx="8" fill="url(#gl)" />
              <line x1="8" y1="20" x2="20" y2="8" stroke="white" stroke-width="2.5" stroke-linecap="round" />
              <defs>
                <linearGradient id="gl" x1="0" y1="0" x2="28" y2="28">
                  <stop offset="0%" stop-color="#6366f1" />
                  <stop offset="100%" stop-color="#8b5cf6" />
                </linearGradient>
              </defs>
            </svg>
          </div>
          <h2 style="margin-top:16px">Welcome to Fenix</h2>
          <p>Sign in to your account</p>
        </div>

        <div class="form-group">
          <label class="form-label">Email</label>
          <input type="email" id="email" class="form-control" placeholder="you@example.com" autofocus>
        </div>
        <div class="form-group">
          <label class="form-label">Password</label>
          <input type="password" id="password" class="form-control" placeholder="••••••••">
        </div>

        <button class="btn btn-primary btn-lg" style="width:100%" id="login-btn">
          Sign In
        </button>

        <p style="text-align:center;margin-top:20px;font-size:0.875rem">
          Don't have an account?
          <a href="/register" style="color:var(--accent-primary);font-weight:600">Sign up</a>
        </p>
      </div>

      <!-- 2FA Form (hidden initially) -->
      <div id="twofa-form" style="display:none">
        <div class="auth-logo">
          <div style="font-size:2.5rem;margin-bottom:12px">🔐</div>
          <h2>Two-Factor Auth</h2>
          <p id="twofa-hint">Enter the 6-digit code</p>
        </div>

        <div class="otp-inputs">
          <input type="text" maxlength="1" class="otp-input" data-index="0">
          <input type="text" maxlength="1" class="otp-input" data-index="1">
          <input type="text" maxlength="1" class="otp-input" data-index="2">
          <input type="text" maxlength="1" class="otp-input" data-index="3">
          <input type="text" maxlength="1" class="otp-input" data-index="4">
          <input type="text" maxlength="1" class="otp-input" data-index="5">
        </div>

        <button class="btn btn-primary btn-lg" style="width:100%" id="verify-btn">
          Verify Code
        </button>

        <p style="text-align:center;margin-top:16px;font-size:0.875rem">
          <a href="#" onclick="backToLogin()" style="color:var(--accent-primary);font-weight:600">← Back to login</a>
        </p>
      </div>

    </div>
  </div>

  <!-- Inline Error Banner (inside auth-card via JS) -->

  <script src="/js/app.js"></script>
  <script>
    window.addEventListener('load', () => { Theme.init(); Toast.init(); });

    let storedUserId = null;

    async function handleLogin() {
      const btn = document.getElementById('login-btn');
      const email = document.getElementById('email').value.trim();
      const pass = document.getElementById('password').value;

      if (!email || !pass) {
        showErrorModal('Missing Fields', 'Please fill in both email and password.');
        return;
      }

      btn.innerHTML = '<div class="spinner"></div> Signing in...';
      btn.disabled = true;

      const data = await API.post('/auth/login', { email, password: pass });

      btn.innerHTML = 'Sign In';
      btn.disabled = false;

      if (data.twofa_required) {
        storedUserId = data.user_id;
        // Show dev code in hint
        document.getElementById('twofa-hint').innerHTML =
          `Dev mode — your code: <strong style="color:var(--accent-primary);font-size:1.1rem;letter-spacing:0.1em">${data.dev_code}</strong>`;
        document.getElementById('login-form').style.display = 'none';
        document.getElementById('twofa-form').style.display = 'block';
        document.querySelector('.otp-input').focus();
      } else {
        showErrorModal('Sign In Failed', data.error || 'Something went wrong. Please try again.');
      }
    }

    async function handleVerify() {
      const inputs = document.querySelectorAll('.otp-input');
      const code = Array.from(inputs).map(i => i.value).join('');
      if (code.length !== 6) {
        showErrorModal('Incomplete Code', 'Please enter all 6 digits.');
        return;
      }

      const btn = document.getElementById('verify-btn');
      btn.innerHTML = '<div class="spinner"></div> Verifying...';
      btn.disabled = true;

      const data = await API.post('/auth/verify-2fa', { user_id: storedUserId, code });

      btn.innerHTML = 'Verify Code';
      btn.disabled = false;

      if (data.token) {
        API.setSession(data.token, data.user);
        Toast.success('Welcome back! 👋');
        setTimeout(() => window.location.href = '/dashboard', 600);
      } else {
        showErrorModal('Wrong Code', data.error || 'Invalid or expired code. Please try again.');
        inputs.forEach(i => { i.value = ''; i.classList.remove('filled'); });
        inputs[0].focus();
      }
    }

    function backToLogin() {
      document.getElementById('twofa-form').style.display = 'none';
      document.getElementById('login-form').style.display = 'block';
      storedUserId = null;
    }

    function showErrorModal(title, msg) {
      // Remove existing banner if any
      const existing = document.getElementById('auth-error-banner');
      if (existing) existing.remove();

      const banner = document.createElement('div');
      banner.id = 'auth-error-banner';
      banner.style.cssText = [
        'display:flex', 'align-items:flex-start', 'gap:10px',
        'padding:12px 16px', 'border-radius:10px', 'margin-bottom:16px',
        'background:linear-gradient(135deg,rgba(239,68,68,0.12),rgba(239,68,68,0.05))',
        'border:1px solid rgba(239,68,68,0.3)',
        'animation:authErrSlide .35s cubic-bezier(.34,1.56,.64,1)',
      ].join(';');
      banner.innerHTML = `
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
        fill="none" stroke="#ef4444" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"
        style="flex-shrink:0;margin-top:1px">
        <circle cx="12" cy="12" r="10"/>
        <line x1="12" y1="8" x2="12" y2="12"/>
        <line x1="12" y1="16" x2="12.01" y2="16"/>
      </svg>
      <div style="flex:1;min-width:0">
        <div style="font-size:0.82rem;font-weight:700;color:#ef4444;margin-bottom:2px">${title}</div>
        <div style="font-size:0.8rem;color:rgba(239,68,68,0.8);line-height:1.4">${msg}</div>
      </div>
      <button onclick="closeErrorModal()" style="background:none;border:none;cursor:pointer;color:rgba(239,68,68,0.5);font-size:1rem;line-height:1;padding:0;flex-shrink:0" title="Dismiss">&#10005;</button>
    `;

      // Insert at the top of whichever form is visible
      const activeForm = document.getElementById('twofa-form').style.display === 'none'
        ? document.getElementById('login-form')
        : document.getElementById('twofa-form');
      activeForm.insertBefore(banner, activeForm.firstChild);

      // shake the input fields
      activeForm.querySelectorAll('.form-control,.otp-input').forEach(el => {
        el.style.animation = 'none';
        el.offsetHeight;
        el.style.borderColor = 'rgba(239,68,68,0.6)';
        el.style.animation = 'authShake 0.4s ease';
        el.addEventListener('input', () => {
          el.style.borderColor = '';
          el.style.animation = '';
        }, { once: true });
      });
    }

    function closeErrorModal() {
      const b = document.getElementById('auth-error-banner');
      if (b) {
        b.style.animation = 'authErrOut .25s ease forwards';
        setTimeout(() => b.remove(), 250);
      }
    }

    // OTP input auto-advance
    document.querySelectorAll('.otp-input').forEach((input, idx, all) => {
      input.addEventListener('input', () => {
        input.value = input.value.replace(/\D/g, '');
        if (input.value) {
          input.classList.add('filled');
          if (idx < all.length - 1) all[idx + 1].focus();
          else document.getElementById('verify-btn').focus();
        } else {
          input.classList.remove('filled');
        }
      });
      input.addEventListener('keydown', e => {
        if (e.key === 'Backspace' && !input.value && idx > 0) {
          all[idx - 1].focus();
          all[idx - 1].classList.remove('filled');
        }
      });
    });

    document.getElementById('login-btn').addEventListener('click', handleLogin);
    document.getElementById('verify-btn').addEventListener('click', handleVerify);
    document.addEventListener('keydown', e => {
      if (e.key === 'Enter') {
        if (document.getElementById('login-form').style.display !== 'none') handleLogin();
        else handleVerify();
      }
    });
  </script>
</body>

</html>